{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "out": "docs/api",
  "tsconfig": "tsconfig.build.json",
  "readme": "README.md",
  "name": "ttasks-ts",
  "includeVersion": true,
  "excludePrivate": true,
  "excludeInternal": true,
  "navigationLinks": {
    "GitHub": "https://github.com/ianphil/ttasks-ts"
  },
  "projectDocuments": [
    "docs/quickstart.md",
    "docs/tutorials/task-execution.md",
    "docs/tutorials/graph-workflows.md",
    "docs/tutorials/copilot.md",
    "docs/patterns/finally-tasks.md",
    "docs/patterns/progress-and-output.md",
    "docs/patterns/retries-and-cancellation.md"
  ],
  "categorizeByGroup": false,
  "defaultCategory": "Other",
  "categoryOrder": [
    "Tasks",
    "Graphs",
    "Executor",
    "Handlers",
    "Stores",
    "Events",
    "Copilot",
    "Errors",
    "*",
    "Other"
  ],
  "navigation": {
    "includeCategories": true,
    "includeGroups": false,
    "includeFolders": false
  }
}

