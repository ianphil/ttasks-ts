{
  "name": "@ianphil/ttasks-ts",
  "version": "0.1.1",
  "description": "TypeScript port of ttasks",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ianphil/ttasks-ts.git"
  },
  "bugs": {
    "url": "https://github.com/ianphil/ttasks-ts/issues"
  },
  "homepage": "https://github.com/ianphil/ttasks-ts#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public",
    "provenance": true
  },
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=24"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs": "typedoc",
    "prepare": "tsc -p tsconfig.build.json"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
